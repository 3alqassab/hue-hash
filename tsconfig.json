{
	"compilerOptions": {
		"target": "es2021",
		"module": "commonjs",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"declaration": true,
		"rootDir": "./src",
		"outDir": "./lib",
		"allowJs": true
	},
	"include": ["src"],
	"exclude": ["node_modules", "lib", "**/__test__/*"]
}
